# Copy this file to `.env` and adjust the local values before starting the stack.
NOMINATIM_IMAGE=mediagis/nominatim:5.3
NOMINATIM_HTTP_PORT=8088
NOMINATIM_SHM_SIZE=1gb
NOMINATIM_THREADS=8
NOMINATIM_TOKENIZER=icu
NOMINATIM_FREEZE=true
NOMINATIM_PBF_PATH=/nominatim/data/parana-latest.osm.pbf
NOMINATIM_PASSWORD=change-me
